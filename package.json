{
  "name": "harnessgate",
  "version": "0.1.1",
  "description": "Universal gateway connecting AI agent runtimes to messaging platforms",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "default": "./dist/providers/index.js"
    },
    "./platforms": {
      "types": "./dist/platforms/index.d.ts",
      "default": "./dist/platforms/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aiwhiteteam/harnessgate.git"
  },
  "homepage": "https://github.com/aiwhiteteam/harnessgate#readme",
  "bugs": {
    "url": "https://github.com/aiwhiteteam/harnessgate/issues"
  },
  "keywords": [
    "claude",
    "anthropic",
    "ai-agents",
    "chatbot",
    "telegram",
    "discord",
    "slack",
    "whatsapp",
    "teams",
    "gateway"
  ],
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "grammy": "^1.35.0",
    "discord.js": "^14.18.0",
    "@slack/bolt": "^4.2.0",
    "botbuilder": "^4.23.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
